# Copie para .env e ajuste se precisar. Usado pelo docker-compose.yml local
# e pelas ferramentas em scripts/ (ex.: migrate-sqlite).
DATABASE_URL=postgresql://gestor:gestor@localhost:5434/gestor

# Credenciais de login do app. Troque os valores abaixo antes de expor o
# app fora da rede local — qualquer pessoa com esse usuário/senha tem acesso
# total aos dados financeiros.
APP_USERNAME=admin
APP_PASSWORD=troque-esta-senha
# Chave usada para assinar o cookie de sessão. Gere uma string aleatória,
# por exemplo com: openssl rand -base64 32
APP_JWT_SECRET=troque-esta-chave-secreta

# Versão da sessão. Ao incrementar este número (ex.: de 1 para 2), todas as
# sessões existentes são invalidadas e os usuários precisam fazer login de
# novo. Útil em caso de suspeita de vazamento do cookie de sessão.
SESSION_VERSION=1

# Chave para criptografar os comprovantes em repouso. Se não for definida,
# o app deriva automaticamente de APP_JWT_SECRET (SHA-256). Se APP_JWT_SECRET
# mudar, os uploads existentes ficam inacessíveis — por isso é recomendado
# definir uma chave fixa aqui. Gere com: openssl rand -base64 32
STORAGE_ENCRYPTION_KEY=troque-esta-chave-de-criptografia

# Senha do banco de dados. Troque antes de expor. Se não for definida,
# o padrão é "gestor" (compatibilidade com instalações existentes).
POSTGRES_PASSWORD=troque-esta-senha-do-banco

# Servidor Ollama usado pra interpretar o texto do OCR de comprovantes
# (extrair valor/data/categoria). Aponta por padrão pro Ollama já rodando
# no zimaos; ajuste se o seu Ollama estiver em outro host.
OLLAMA_URL=http://192.168.1.10:11434
OLLAMA_MODEL=qwen2.5vl:3b

# Só necessário se você expõe o app pela internet através de um reverse
# proxy ou túnel que roda no mesmo host em modo "network host" (ex.:
# cloudflared do Cloudflare Tunnel, Tailscale Funnel). Coloque o IP desse
# proxy na rede local (separe por vírgula se houver mais de um). Sem isso, o
# app só confia em requisições vindas dele mesmo (loopback) — deixar em
# branco com um proxy desses na frente faz o rate limit do login e o cookie
# "Secure" não reconhecerem o IP/protocolo real do visitante corretamente.
TRUSTED_PROXY_IP=
