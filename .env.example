# Copie para .env e ajuste se precisar. Usado pelo docker-compose.yml local
# e pelas ferramentas em scripts/ (ex.: migrate-sqlite).
DATABASE_URL=postgresql://gestor:gestor@localhost:5434/gestor

# Credenciais de login do app. Troque os valores abaixo antes de expor o
# app fora da rede local — qualquer pessoa com esse usuário/senha tem acesso
# total aos dados financeiros.
APP_USERNAME=admin
APP_PASSWORD=troque-esta-senha
# Chave usada para assinar o cookie de sessão. Gere uma string aleatória,
# por exemplo com: openssl rand -base64 32
APP_JWT_SECRET=troque-esta-chave-secreta
