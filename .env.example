DATABASE_URL="file:./dev.db"

# Chave usada para assinar o cookie de sessão. Gere uma própria, por exemplo com:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="troque-este-valor"

# Usuário inicial criado por "npm run db:seed" caso ainda não exista.
# Defina apenas no primeiro start; depois disso a senha já está hasheada no banco.
SEED_USERNAME="admin"
SEED_PASSWORD="troque-esta-senha"
